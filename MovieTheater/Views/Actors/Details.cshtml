@model MovieTheater.Models.Actor

@{
    ViewData["Title"] = "Actor profile";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

    body {
        background-color: #050508;
        color: #ffffff;
        font-family: 'Plus Jakarta Sans', sans-serif;
        min-height: 100vh;
        margin: 0;
    }

    main, .container { background: transparent !important; }

    .ambient-background {
        position: fixed;
        top: 0; left: 0; width: 100vw; height: 100vh;
        z-index: -1;
        background: 
            radial-gradient(circle at 10% 10%, rgba(254, 1, 154, 0.08), transparent 40%),
            radial-gradient(circle at 90% 90%, rgba(176, 38, 255, 0.05), transparent 40%);
        pointer-events: none;
    }

    .glass-details-container {
        max-width: 850px;
        margin: 40px auto;
        background: rgba(13, 13, 18, 0.6);
        backdrop-filter: blur(25px);
        -webkit-backdrop-filter: blur(25px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-top: 1px solid rgba(254, 1, 154, 0.3); 
        border-radius: 24px;
        padding: 50px;
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6), 0 0 40px rgba(254, 1, 154, 0.05);
    }

    .details-header {
        margin-bottom: 35px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 25px;
    }

    .actor-full-name {
        font-size: 3.5rem;
        font-weight: 800;
        letter-spacing: -1.5px;
        margin: 0;
        line-height: 1.1;
        background: linear-gradient(90deg, #ffffff, #fe019a);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .info-row {
        display: flex;
        gap: 30px;
        margin-bottom: 40px;
    }

    .info-item {
        flex: 1;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 20px;
    }

    .info-label {
        color: #718096;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 700;
        display: block;
        margin-bottom: 10px;
    }

    .info-text {
        font-size: 1.2rem;
        font-weight: 600;
        color: #e2e8f0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .neon-dot { width: 8px; height: 8px; border-radius: 50%; background: #fe019a; box-shadow: 0 0 10px #fe019a; }

    .bio-section {
        background: rgba(0, 0, 0, 0.2);
        border-radius: 16px;
        padding: 25px;
        margin-bottom: 40px;
        line-height: 1.7;
        color: #cbd5e0;
        border-left: 3px solid #fe019a;
    }

    .section-title {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 20px;
        color: #ffffff;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .film-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .film-link {
        background: rgba(0, 243, 255, 0.05);
        border: 1px solid rgba(0, 243, 255, 0.2);
        color: #00f3ff;
        padding: 10px 20px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .film-link:hover {
        background: rgba(0, 243, 255, 0.15);
        border-color: #00f3ff;
        color: #ffffff;
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0, 243, 255, 0.2);
    }

    .action-btns {
        display: flex;
        gap: 15px;
        margin-top: 50px;
        padding-top: 30px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .btn-custom {
        flex: 1;
        padding: 14px;
        border-radius: 12px;
        font-weight: 700;
        text-align: center;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
    }

    .btn-edit-actor { background: rgba(254, 1, 154, 0.1); border: 1px solid #fe019a; color: #fe019a; }
    .btn-edit-actor:hover { background: #fe019a; color: #ffffff; box-shadow: 0 0 20px rgba(254, 1, 154, 0.3); }

    .btn-back-list { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1); color: #a0aec0; }
    .btn-back-list:hover { background: rgba(255, 255, 255, 0.1); color: #ffffff; }
</style>

<div class="ambient-background"></div>

<div class="glass-details-container">

    <div class="details-header">
        <h1 class="actor-full-name">@Model.FirstName <br> @Model.LastName</h1>
    </div>

    <div class="info-row">
        <div class="info-item">
            <span class="info-label">Дата народження</span>
            <span class="info-text">
                <span class="neon-dot"></span> 
                @Convert.ToDateTime(Model.BirthDate).ToString("dd MMMM yyyy")
            </span>
        </div>
        <div class="info-item">
            <span class="info-label">Країна</span>
            <span class="info-text">
                <span class="neon-dot"></span> 
                @Model.Country
            </span>
        </div>
    </div>

    <div class="section-title">🎞️ Біографія</div>
    <div class="bio-section">
        @if (string.IsNullOrEmpty(Model.Biography))
        {                
            <span style= "color: #718096; font-style: italic;">Біографія поки що відсутня.</span>
        }
        else
        {
            @Model.Biography
        }
    </div>

    <div class="section-title">🎬 Фільмографія</div>
    <div class="film-chips">
        @if (Model.ActorMovies != null && Model.ActorMovies.Any())
        {
            @foreach (var item in Model.ActorMovies)
            {
                <a asp-controller="Movies" asp-action="Details" asp-route-id="@item.MovieId" class="film-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M0 1a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V1zm4 0v6h8V1H4zm8 8H4v6h8V9zM1 1v2h2V1H1zm2 3H1v2h2V4zM1 7v2h2V7H1zm2 3H1v2h2v-2zm-2 3v2h2v-2H1zM15 1h-2v2h2V1zm-2 3v2h2V4h-2zm2 3h-2v2h2V7zm-2 3v2h2v-2h-2zm2 3h-2v2h2v-2z"/>
                    </svg>
                    @item.Movie.Title (@item.Movie.ReleaseYear)
                </a>
            }
        }
        else
        {
            <span style="color: #718096; font-style: italic;">Дані про фільми відсутні.</span>
        }
    </div>

    <div class="action-btns">
        <a asp-action="Index" class="btn-custom btn-back-list">Повернутися до списку</a>
        @if (User.Identity.IsAuthenticated)
        {
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-custom btn-edit-actor">Редагувати профіль</a>
        }
    </div>

</div>
@model MovieTheater.Models.Movie

@{
    ViewData["Title"] = "Movie details";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

    body {
        background-color: #050508;
        color: #ffffff;
        font-family: 'Plus Jakarta Sans', sans-serif;
        min-height: 100vh;
        margin: 0;
    }

    main, .container { background: transparent !important; }

    .ambient-background {
        position: fixed;
        top: 0; left: 0; width: 100vw; height: 100vh;
        z-index: -1;
        background: 
            radial-gradient(circle at 10% 10%, rgba(0, 243, 255, 0.08), transparent 40%),
            radial-gradient(circle at 90% 90%, rgba(254, 1, 154, 0.05), transparent 40%);
        pointer-events: none;
    }

    .glass-details-container {
        max-width: 800px;
        margin: 40px auto;
        background: rgba(13, 13, 18, 0.6);
        backdrop-filter: blur(25px);
        -webkit-backdrop-filter: blur(25px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-top: 1px solid rgba(0, 243, 255, 0.3);
        border-radius: 24px;
        padding: 35px;
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6), 0 0 40px rgba(0, 243, 255, 0.05);
        position: relative;
        overflow: hidden;
    }

    .glass-details-container::before {
        content: '';
        position: absolute;
        top: 0; left: -100%;
        width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.02), transparent);
        transform: skewX(-20deg);
        transition: 1s;
    }
    .glass-details-container:hover::before { left: 200%; }

    .details-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 25px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 20px;
    }

    .movie-title {
        font-size: 2.2rem;
        font-weight: 800;
        letter-spacing: -1px;
        margin: 0;
        line-height: 1.1;
        background: linear-gradient(90deg, #ffffff, #e2e8f0);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .rating-badge-large {
        background: rgba(255, 215, 0, 0.1);
        border: 1px solid rgba(255, 215, 0, 0.3);
        color: #ffd700;
        padding: 8px 16px;
        border-radius: 14px;
        font-size: 1.2rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 0 20px rgba(255, 215, 0, 0.1);
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 15px;
        margin-bottom: 30px;
    }

    .info-box {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 15px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .info-label {
        color: #718096;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .info-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: #ffffff;
    }

    .neon-dot { width: 8px; height: 8px; border-radius: 50%; }
    .dot-cyan { background: #00f3ff; box-shadow: 0 0 10px #00f3ff; }
    .dot-purple { background: #b026ff; box-shadow: 0 0 10px #b026ff; }
    .dot-pink { background: #fe019a; box-shadow: 0 0 10px #fe019a; }

    .actors-section {
        margin-bottom: 30px;
    }

    .section-title {
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 15px;
        color: #e2e8f0;
    }

    .actor-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .actor-chip {
        background: rgba(176, 38, 255, 0.08);
        border: 1px solid rgba(176, 38, 255, 0.3);
        color: #d896ff;
        padding: 8px 14px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none; 
        letter-spacing: 0.3px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer; 
    }

    .actor-chip:hover {
        background: rgba(176, 38, 255, 0.15);
        color: #ffffff;
        border-color: #b026ff;
        box-shadow: 0 10px 20px rgba(176, 38, 255, 0.2);
        transform: translateY(-3px) scale(1.05);
    }

    .empty-text {
        color: #718096;
        font-style: italic;
        font-size: 0.9rem;
    }

    .form-actions {
        display: flex;
        flex-wrap: nowrap;
        gap: 10px;
        margin-top: 15px;
    }

    .btn-action {
        padding: 10px 15px;
        font-size: 0.85rem;
        border-radius: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        text-align: center;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        font-family: inherit;
        cursor: pointer;
        flex: 1;
        white-space: nowrap;
    }

    .btn-edit {
        background: rgba(0, 243, 255, 0.1);
        border: 1px solid #00f3ff;
        color: #00f3ff;
    }

    .btn-edit:hover {
        background: #00f3ff;
        color: #050508;
        box-shadow: 0 0 25px rgba(0, 243, 255, 0.5);
    }

    .btn-back {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #a0aec0;
    }

    .btn-back:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #ffffff;
    }

    #chatMessages::-webkit-scrollbar { width: 6px; }
    #chatMessages::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); border-radius: 10px; }
    #chatMessages::-webkit-scrollbar-thumb { background: rgba(0, 243, 255, 0.3); border-radius: 10px; }
    #chatMessages::-webkit-scrollbar-thumb:hover { background: rgba(0, 243, 255, 0.6); }

    .chat-input {
        flex-grow: 1;
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(0, 243, 255, 0.3);
        color: #fff;
        border-radius: 12px;
        padding: 12px 20px;
        outline: none;
        font-family: inherit;
        transition: 0.3s;
    }
    .chat-input:focus {
        border-color: #00f3ff;
        box-shadow: 0 0 15px rgba(0, 243, 255, 0.2);
    }
</style>

<div class="container mt-5 pt-3 mb-5" style="min-height: 85vh;">
    <div class="row g-4 align-items-stretch">
        <div class="col-lg-7">
            <div class="ambient-background"></div>
            <div class="glass-details-container h-100 d-flex flex-column" style="position: relative; z-index: 1;">
                <div class="details-header">
                    <h1 class="movie-title">@Model.Title</h1>
                    <div class="rating-badge-large">
                        ★ @Html.DisplayFor(model => model.Rating)
                    </div>
                </div>

                <div class="info-grid">
                    <div class="info-box">
                        <span class="info-label"><span class="neon-dot dot-cyan"></span> Рік випуску</span>
                        <span class="info-value">@Html.DisplayFor(model => model.ReleaseYear)</span>
                    </div>

                    <div class="info-box">
                        <span class="info-label"><span class="neon-dot dot-purple"></span> Жанр</span>
                        <span class="info-value">@Html.DisplayFor(model => model.Genre)</span>
                    </div>

                    <div class="info-box">
                        <span class="info-label"><span class="neon-dot dot-pink"></span> Тривалість</span>
                        <span class="info-value">@Html.DisplayFor(model => model.DurationMinutes) хв</span>
                    </div>
                </div>

                <div class="actors-section">
                    <h3 class="section-title">Акторський склад</h3>
                    @if (Model.ActorMovies != null && Model.ActorMovies.Any())
                    {
                        <div class="actor-chips">
                            @foreach (var item in Model.ActorMovies)
                            {
                                <a asp-controller="Actors" asp-action="Details" asp-route-id="@item.ActorId" class="actor-chip">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                                    </svg>
                                @item.Actor.FirstName @item.Actor.LastName
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <span class="empty-text">Немає даних про акторів.</span>
                    }
                </div>

                <div class="form-actions mt-auto pt-3">
                    <a asp-action="Index" class="btn-action btn-back">Повернутися до списку</a>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-action btn-edit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
                            </svg>
                            Редагувати запис
                        </a>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="glass-details-container h-100 d-flex flex-column" style="position: relative; z-index: 1;">

                <h3 class="section-title text-center mb-3" style="font-size: 1.1rem; letter-spacing: 1px;">
                    <span class="neon-dot dot-cyan"></span> ОБГОВОРЕННЯ ФІЛЬМУ
                </h3>

                <div id="chatMessages" class="flex-grow-1" style="overflow-y: auto; background: rgba(0,0,0,0.3); border-radius: 16px; padding: 20px; display: flex; flex-direction: column; gap: 15px; border: 1px solid rgba(255,255,255,0.05); height: 0; min-height: 250px;">

                    @if (ViewBag.ChatMessages != null)
                    {
                        foreach (var msg in ViewBag.ChatMessages)
                        {
                            bool isMe = User.Identity.IsAuthenticated && msg.UserName == User.Identity.Name;

                            string attachmentHtml = "";
                            if (!string.IsNullOrEmpty(msg.ImageUrl))
                            {
                                if (msg.ImageUrl.StartsWith("data:image/"))
                                {
                                    attachmentHtml = $"<br/><img src='{msg.ImageUrl}' style='max-width: 100%; border-radius: 8px; margin-top: 8px;' />";
                                }
                                else
                                {
                                    string fName = string.IsNullOrEmpty(msg.FileName) ? "Завантажити файл" : msg.FileName;
                                    attachmentHtml = $"<br/><a href='{msg.ImageUrl}' download='{fName}' class='btn-action btn-back' style='display: inline-flex; margin-top: 8px; font-size: 0.8rem; padding: 8px 12px; border-radius: 8px; text-decoration: none;'><svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' fill='currentColor' viewBox='0 0 16 16' style='margin-right: 5px;'><path d='M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z'/><path d='M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z'/></svg> {fName}</a>";
                                }
                            }

                            if (isMe)
                            {
                                <div style="padding: 12px 18px; border-radius: 18px 18px 0 18px; max-width: 85%; word-break: break-word; background: rgba(0, 243, 255, 0.15); border: 1px solid rgba(0, 243, 255, 0.4); color: #fff; align-self: flex-end; box-shadow: 0 4px 15px rgba(0,0,0,0.2);">
                                    <small style="color: #00f3ff; font-weight: 700; font-size: 0.75rem; letter-spacing: 0.5px;">ВИ</small><br/><span style="font-size: 0.95rem; line-height: 1.4;">@msg.Text</span> @Html.Raw(attachmentHtml)
                                </div>
                            }
                            else
                            {
                                <div style="padding: 12px 18px; border-radius: 18px 18px 18px 0; max-width: 85%; word-break: break-word; background: rgba(254, 1, 154, 0.15); border: 1px solid rgba(254, 1, 154, 0.4); color: #fff; align-self: flex-start; box-shadow: 0 4px 15px rgba(0,0,0,0.2);">
                                    <small style="color: #fe019a; font-weight: 700; font-size: 0.75rem; letter-spacing: 0.5px;">@msg.UserName.Split('@')[0].ToUpper()</small><br/><span style="font-size: 0.95rem; line-height: 1.4;">@msg.Text</span> @Html.Raw(attachmentHtml)
                                </div>
                            }
                        }
                    }

                </div>

                <div class="mt-auto pt-4">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div style="display: flex; gap: 8px; width: 100%;">
                            <input type="hidden" id="movieIdInput" value="@Model.Id" />
                            <input type="hidden" id="userNameInput" value="@User.Identity.Name" />

                            <label class="btn-action btn-back m-0" style="padding: 12px 15px; cursor: pointer; flex-shrink: 0; flex: 0;" title="Прикріпити файл">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M4.5 3a2.5 2.5 0 0 1 5 0v9a1.5 1.5 0 0 1-3 0V5a.5.5 0 0 1 1 0v7a.5.5 0 0 0 1 0V3a1.5 1.5 0 1 0-3 0v9a2.5 2.5 0 0 0 5 0V5a.5.5 0 0 1 1 0v7a3.5 3.5 0 1 1-7 0V3z"/>
                                </svg>
                                <input type="file" id="fileInput" style="display: none;" />
                            </label>

                            <input type="text" id="messageInput" class="chat-input" placeholder="Напишіть текст..." style="flex-grow: 1; min-width: 0; padding: 12px 15px;" />

                            <button id="sendButton" class="btn-action btn-edit m-0" style="padding: 12px 20px; flex-shrink: 0; flex: 0; border-width: 1px;">
                                Надіслати
                            </button>
                        </div>
                        <div id="fileNameDisplay" style="color: #00f3ff; font-size: 0.85rem; margin-top: 8px; text-align: right; display: none;"></div>
                    }
                    else
                    {
                        <div style="background: rgba(254, 1, 154, 0.05); border: 1px dashed rgba(254, 1, 154, 0.4); border-radius: 12px; padding: 15px; text-align: center;">
                            <span style="color: rgba(255,255,255,0.7);">Щоб долучитися до чату, потрібно <a asp-area="Identity" asp-page="/Account/Login" style="color: #fe019a; font-weight: bold; text-decoration: none;">увійти</a>.</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
        <script>
            const connection = new signalR.HubConnectionBuilder().withUrl("/movieChatHub").build();
            const movieId = document.getElementById("movieIdInput")?.value;
            const sendButton = document.getElementById("sendButton");
            const messageInput = document.getElementById("messageInput");
            const fileInput = document.getElementById("fileInput");
            const fileNameDisplay = document.getElementById("fileNameDisplay");

            if (fileInput) {
                fileInput.addEventListener("change", function() {
                    if (this.files && this.files[0]) {
                        fileNameDisplay.innerText = "✓ Готово: " + this.files[0].name;
                        fileNameDisplay.style.display = "block";
                    } else {
                        fileNameDisplay.style.display = "none";
                    }
                });
            }

            connection.on("ReceiveMessage", function (user, message, fileData, fileName, receiverName) {
                if (receiverName) return;

                const myUserName = document.getElementById("userNameInput")?.value;
                const msgList = document.getElementById("chatMessages");
                const isMe = user === myUserName;

                const msgElement = document.createElement("div");
                msgElement.style.padding = "12px 18px";
                msgElement.style.maxWidth = "85%";
                msgElement.style.wordBreak = "break-word";
                msgElement.style.boxShadow = "0 4px 15px rgba(0,0,0,0.2)";

                let attachmentHtml = "";
                if (fileData) {
                    if (fileData.startsWith("data:image/")) {
                        attachmentHtml = `<br/><img src="${fileData}" style="max-width: 100%; border-radius: 8px; margin-top: 8px;" />`;
                    } else {
                        let fName = fileName ? fileName : "Завантажити файл";
                        attachmentHtml = `<br/><a href="${fileData}" download="${fName}" class="btn-action btn-back" style="display: inline-flex; margin-top: 8px; font-size: 0.8rem; padding: 8px 12px; border-radius: 8px; text-decoration: none;"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" style="margin-right: 5px;"><path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/><path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/></svg> ${fName}</a>`;
                    }
                }

                if (isMe) {
                    msgElement.style.borderRadius = "18px 18px 0 18px";
                    msgElement.style.background = "rgba(0, 243, 255, 0.15)";
                    msgElement.style.border = "1px solid rgba(0, 243, 255, 0.4)";
                    msgElement.style.color = "#fff";
                    msgElement.style.alignSelf = "flex-end";
                    msgElement.innerHTML = `<small style="color: #00f3ff; font-weight: 700; font-size: 0.75rem; letter-spacing: 0.5px;">ВИ</small><br/><span style="font-size: 0.95rem; line-height: 1.4;">${message}</span> ${attachmentHtml}`;
                } else {
                    msgElement.style.borderRadius = "18px 18px 18px 0";
                    msgElement.style.background = "rgba(254, 1, 154, 0.15)";
                    msgElement.style.border = "1px solid rgba(254, 1, 154, 0.4)";
                    msgElement.style.color = "#fff";
                    msgElement.style.alignSelf = "flex-start";
                    msgElement.innerHTML = `<small style="color: #fe019a; font-weight: 700; font-size: 0.75rem; letter-spacing: 0.5px;">${user.split('@@')[0].toUpperCase()}</small><br/><span style="font-size: 0.95rem; line-height: 1.4;">${message}</span> ${attachmentHtml}`;
                }

                msgList.appendChild(msgElement);
                msgList.scrollTop = msgList.scrollHeight;
            });

            if (movieId) {
                connection.start().then(function () {
                    connection.invoke("JoinMovieGroup", movieId.toString()).catch(err => console.error(err));
                });
            }

            if (sendButton) {
                sendButton.addEventListener("click", function (event) {
                    event.preventDefault();
                    const user = document.getElementById("userNameInput").value;
                    const message = messageInput.value;
                    const file = fileInput.files[0];

                    if (file) {
                        const fileName = file.name;
                        const reader = new FileReader();
                        reader.onload = function(e) {
                            const base64Data = e.target.result;
                            connection.invoke("SendMessageToMovie", movieId.toString(), user, message, base64Data, fileName)
                                .catch(err => console.error(err.toString()));

                            messageInput.value = "";
                            fileInput.value = "";
                            fileNameDisplay.style.display = "none";
                        };
                        reader.readAsDataURL(file);
                    } else if (message.trim() !== "") {
                        connection.invoke("SendMessageToMovie", movieId.toString(), user, message, null, null)
                            .catch(err => console.error(err.toString()));
                        messageInput.value = ""; 
                    }
                });

                messageInput.addEventListener("keypress", function (e) {
                    if (e.key === 'Enter') sendButton.click();
                });
            }

            window.onload = function() {
                const msgList = document.getElementById("chatMessages");
                if(msgList) msgList.scrollTop = msgList.scrollHeight;
            };
        </script>
}
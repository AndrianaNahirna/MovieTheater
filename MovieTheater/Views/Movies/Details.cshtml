@model MovieTheater.Models.Movie

@{
    ViewData["Title"] = "Movie details";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

    body {
        background-color: #050508;
        color: #ffffff;
        font-family: 'Plus Jakarta Sans', sans-serif;
        min-height: 100vh;
        margin: 0;
    }

    main, .container { background: transparent !important; }

    .ambient-background {
        position: fixed;
        top: 0; left: 0; width: 100vw; height: 100vh;
        z-index: -1;
        background: 
            radial-gradient(circle at 10% 10%, rgba(0, 243, 255, 0.08), transparent 40%),
            radial-gradient(circle at 90% 90%, rgba(254, 1, 154, 0.05), transparent 40%);
        pointer-events: none;
    }

    .glass-details-container {
        max-width: 800px;
        margin: 40px auto;
        background: rgba(13, 13, 18, 0.6);
        backdrop-filter: blur(25px);
        -webkit-backdrop-filter: blur(25px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-top: 1px solid rgba(0, 243, 255, 0.3);
        border-radius: 24px;
        padding: 50px;
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6), 0 0 40px rgba(0, 243, 255, 0.05);
        position: relative;
        overflow: hidden;
    }

    .glass-details-container::before {
        content: '';
        position: absolute;
        top: 0; left: -100%;
        width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.02), transparent);
        transform: skewX(-20deg);
        transition: 1s;
    }
    .glass-details-container:hover::before { left: 200%; }

    .details-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 40px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 30px;
    }

    .movie-title {
        font-size: 3rem;
        font-weight: 800;
        letter-spacing: -1px;
        margin: 0;
        line-height: 1.1;
        background: linear-gradient(90deg, #ffffff, #e2e8f0);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .rating-badge-large {
        background: rgba(255, 215, 0, 0.1);
        border: 1px solid rgba(255, 215, 0, 0.3);
        color: #ffd700;
        padding: 10px 20px;
        border-radius: 14px;
        font-size: 1.5rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 0 20px rgba(255, 215, 0, 0.1);
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .info-box {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .info-label {
        color: #718096;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .info-value {
        font-size: 1.4rem;
        font-weight: 700;
        color: #ffffff;
    }

    .neon-dot { width: 8px; height: 8px; border-radius: 50%; }
    .dot-cyan { background: #00f3ff; box-shadow: 0 0 10px #00f3ff; }
    .dot-purple { background: #b026ff; box-shadow: 0 0 10px #b026ff; }
    .dot-pink { background: #fe019a; box-shadow: 0 0 10px #fe019a; }

    .actors-section {
        margin-bottom: 40px;
    }

    .section-title {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 20px;
        color: #e2e8f0;
    }

    .actor-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .actor-chip {
        background: rgba(176, 38, 255, 0.08);
        border: 1px solid rgba(176, 38, 255, 0.3);
        color: #d896ff;
        padding: 10px 20px;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none; 
        letter-spacing: 0.3px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer; 
    }

    .actor-chip:hover {
        background: rgba(176, 38, 255, 0.15);
        color: #ffffff;
        border-color: #b026ff;
        box-shadow: 0 10px 20px rgba(176, 38, 255, 0.2);
        transform: translateY(-3px) scale(1.05);
    }

    .empty-text {
        color: #718096;
        font-style: italic;
    }

    .form-actions {
        display: flex;
        gap: 15px;
        margin-top: 20px;
    }

    .btn-action {
        flex: 1;
        padding: 14px;
        border-radius: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-align: center;
        text-decoration: none;
        transition: all 0.3s ease;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
    }

    .btn-edit {
        background: rgba(0, 243, 255, 0.1);
        border: 1px solid #00f3ff;
        color: #00f3ff;
    }

    .btn-edit:hover {
        background: #00f3ff;
        color: #050508;
        box-shadow: 0 0 25px rgba(0, 243, 255, 0.5);
    }

    .btn-back {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #a0aec0;
    }

    .btn-back:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #ffffff;
    }
</style>

<div class="ambient-background"></div>

<div class="glass-details-container">

    <div class="details-header">
        <h1 class="movie-title">@Model.Title</h1>
        <div class="rating-badge-large">
            ★ @Html.DisplayFor(model => model.Rating)
        </div>
    </div>

    <div class="info-grid">
        <div class="info-box">
            <span class="info-label"><span class="neon-dot dot-cyan"></span> Рік випуску</span>
            <span class="info-value">@Html.DisplayFor(model => model.ReleaseYear)</span>
        </div>

        <div class="info-box">
            <span class="info-label"><span class="neon-dot dot-purple"></span> Жанр</span>
            <span class="info-value">@Html.DisplayFor(model => model.Genre)</span>
        </div>

        <div class="info-box">
            <span class="info-label"><span class="neon-dot dot-pink"></span> Тривалість</span>
            <span class="info-value">@Html.DisplayFor(model => model.DurationMinutes) хв</span>
        </div>
    </div>

    <div class="actors-section">
        <h3 class="section-title">Акторський склад</h3>

        @if (Model.ActorMovies != null && Model.ActorMovies.Any())
        {
            <div class="actor-chips">
                @foreach (var item in Model.ActorMovies)
                {
                <a asp-controller="Actors" asp-action="Details" asp-route-id="@item.ActorId" class="actor-chip">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                    </svg>
                        @item.Actor.FirstName @item.Actor.LastName
                </a>
                }
            </div>
        }
        else
        {
                <span class="empty-text">Немає даних про акторів для цього фільму.</span>
        }
    </div>

    <div class="form-actions">
        <a asp-action="Index" class="btn-action btn-back">Повернутися до списку</a>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-action btn-edit">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
            </svg>
            Редагувати запис
        </a>
    </div>

</div>
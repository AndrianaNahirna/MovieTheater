@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<div class="identity-container">
    <div class="identity-box">
        <h1 class="identity-title">MOVIETHEATER</h1>
        <h2 class="identity-subtitle">Увійдіть у свій акаунт</h2>
        <hr class="identity-hr" />

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-floating mb-3 identity-input-group">
                <input asp-for="Input.Email" class="form-control identity-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="identity-label">Електронна пошта</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3 identity-input-group">
                <input asp-for="Input.Password" class="form-control identity-input" autocomplete="current-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.Password" class="identity-label">Пароль</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="checkbox mb-4">
                <label asp-for="Input.RememberMe" class="form-label" style="color: rgba(255, 255, 255, 0.7);">
                    <input class="form-check-input" asp-for="Input.RememberMe" style="background-color: transparent; border-color: rgba(255,255,255,0.3); accent-color: #ff007f;" />
                    Запам'ятати мене
                </label>
            </div>

            <button id="login-submit" type="submit" class="identity-button">Увійти</button>

           
            <div class="mt-4 text-center">
                <p>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" style="color: #ff007f; text-decoration: none;">Ще немає акаунта? Зареєструватися</a>
                </p>
                @* 
                <p>
                    <a id="forgot-password" asp-page="./ForgotPassword" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.85rem;">Забули пароль?</a>
                </p>
                *@
            </div>
        </form>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}
@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="identity-container">
    <div class="identity-box">
        <h1 class="identity-title">MOVIETHEATER</h1>
        <h2 class="identity-subtitle">Створіть новий акаунт</h2>
        <hr class="identity-hr" />

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-floating mb-3 identity-input-group">
                <input asp-for="Input.Email" class="form-control identity-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="identity-label">Електронна пошта</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3 identity-input-group">
                <input asp-for="Input.Password" class="form-control identity-input" autocomplete="new-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.Password" class="identity-label">Пароль</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3 identity-input-group">
                <input asp-for="Input.ConfirmPassword" class="form-control identity-input" autocomplete="new-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.ConfirmPassword" class="identity-label">Підтвердження пароля</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button id="registerSubmit" type="submit" class="identity-button">Зареєструватися</button>
        </form>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}